FL_DB_NAME=flotte
FL_DB_USER=flotte
FL_DB_PASSWORD=change-me-strong-password
FL_JWT_SECRET=change-me-random-secret-32-chars

# Envoi d'email (page Présence Pérols + envoi des tableaux à la compta)
# Réutilise le compte Resend du site web. RESEND_FROM doit être une adresse
# d'un domaine vérifié dans Resend (ex. Montpellier Dépannage <flotte@montpellierdepannage.com>).
FL_RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
FL_RESEND_FROM=Flotte Montpellier Dépannage <flotte@montpellierdepannage.com>
FL_MAIL_TO=compta@montpellierdepannage.com

# Secret partagé avec le dashboard de pilotage du site web. Protège
# l'endpoint GET /api/pilotage-public/snapshot (compteurs de contrôle
# technique). Laisser vide pour désactiver l'endpoint.
#   openssl rand -base64 32
FL_PILOTAGE_SECRET=
